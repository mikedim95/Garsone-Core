# Copy this file to .env next to compose.yml on the Raspberry Pi.

# Docker Hub namespace or organization containing the pushed images.
DOCKERHUB_NAMESPACE=your-dockerhub-user
IMAGE_TAG=pi

# Public ports exposed by the Pi.
FRONT_PORT=8080
CORE_PORT=8787

# Local Postgres credentials. Change POSTGRES_PASSWORD before first boot.
# Keep it URL-safe here because compose uses it inside DATABASE_URL.
POSTGRES_DB=garsone
POSTGRES_USER=garsone
POSTGRES_PASSWORD=change-this-password

# Backend auth secret. Use a long random value.
JWT_SECRET=change-this-to-a-long-random-secret

# First local Pi install should use push because this repo has no baseline
# Prisma migration for a completely empty database.
DB_BOOTSTRAP_MODE=push
DB_WAIT_TIMEOUT_SECONDS=90

# Set these to the hostname or LAN IP that phones/tablets will use.
FRONTEND_ORIGIN=http://raspberrypi.local:8080
FRONTEND_BASE_URL=http://raspberrypi.local:8080
PUBLIC_APP_BASE_URL=http://raspberrypi.local:8080
PUBLIC_APP_PROTOCOL=http
PUBLIC_APP_DOMAIN=raspberrypi.local
PUBLIC_APP_PORT=8080
FRONTEND_PORT=8080

# Keep MQTT off unless you add a broker service or an external broker URL.
MQTT_DISABLED=true

# Optional operational toggles.
LOG_LEVEL=info
STORE_SLUG=default-store
ENABLE_DEV_LOGIN=0
DB_SEED_ON_START=false
