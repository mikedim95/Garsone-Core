generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Store {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String             @unique @db.VarChar(100)
  name              String             @db.VarChar(255)
  settingsJson      Json?
  createdAt         DateTime           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime           @updatedAt @db.Timestamp(6)
  auditLogs         AuditLog[]
  categories        Category[]
  cookTypes         CookType[]
  itemModifiers     ItemModifier[]
  items             Item[]
  kitchenCounters   KitchenCounter[]
  kitchenTicketSeqs KitchenTicketSeq[]
  modifierOptions   ModifierOption[]
  modifiers         Modifier[]
  orders            Order[]
  customerPushSubscriptions CustomerPushSubscription[]
  profiles          Profile[]
  qrTiles           QRTile[]
  storeMeta         StoreMeta?
  tableVisits       TableVisit[]
  tables            Table[]
  waiterShifts      WaiterShift[]
  waiterTables      WaiterTable[]
  waiterTypes       WaiterType[]
  localityApprovals LocalityApproval[]
  nodeAgents        NodeAgent[]
  pendingNodeAgents PendingNodeAgent[]

  @@index([createdAt(sort: Desc)])
  @@map("stores")
}

model StoreMeta {
  storeId      String   @id @db.Uuid
  currencyCode String   @db.VarChar(8)
  locale       String   @db.VarChar(16)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_meta")
}

model Category {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String   @db.Uuid
  slug         String   @db.VarChar(100)
  title        String   @db.VarChar(255)
  titleEl      String?  @db.VarChar(255)
  titleEn      String?  @db.VarChar(255)
  imageUrl     String?  @db.VarChar(2000)
  printerTopic String?  @db.VarChar(255)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([storeId, slug])
  @@index([storeId, sortOrder])
  @@map("categories")
}

model CookType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String    @db.Uuid
  slug         String    @db.VarChar(100)
  title        String    @db.VarChar(255)
  printerTopic String?   @db.VarChar(255)
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cooks        Profile[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("cook_types")
}

model WaiterType {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String    @db.Uuid
  slug         String    @db.VarChar(100)
  title        String    @db.VarChar(255)
  printerTopic String?   @db.VarChar(255)
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  waiters      Profile[]
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("waiter_types")
}

model Item {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId       String         @db.Uuid
  categoryId    String         @db.Uuid
  slug          String         @db.VarChar(120)
  title         String         @db.VarChar(255)
  titleEl       String?        @db.VarChar(255)
  titleEn       String?        @db.VarChar(255)
  subcategoryEn String?        @db.VarChar(255)
  subcategoryEl String?        @db.VarChar(255)
  description   String?        @db.VarChar(2000)
  descriptionEl String?        @db.VarChar(2000)
  descriptionEn String?        @db.VarChar(2000)
  imageUrl      String?        @db.VarChar(2000)
  printerTopic  String?        @db.VarChar(255)
  priceCents    Int
  isAvailable   Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now()) @db.Timestamp(6)
  updatedAt     DateTime       @updatedAt @db.Timestamp(6)
  itemModifiers ItemModifier[]
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@unique([storeId, slug])
  @@index([storeId, categoryId, sortOrder])
  @@map("items")
}

model Modifier {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId         String            @db.Uuid
  slug            String            @db.VarChar(120)
  title           String            @db.VarChar(255)
  titleEl         String?           @db.VarChar(255)
  titleEn         String?           @db.VarChar(255)
  minSelect       Int               @default(0)
  maxSelect       Int               @default(1)
  isAvailable     Boolean           @default(true)
  createdAt       DateTime          @default(now()) @db.Timestamp(6)
  updatedAt       DateTime          @updatedAt @db.Timestamp(6)
  itemLinks       ItemModifier[]
  modifierOptions ModifierOption[]
  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderOptions    OrderItemOption[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("modifiers")
}

model ModifierOption {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId          String            @db.Uuid
  modifierId       String            @db.Uuid
  slug             String            @db.VarChar(120)
  title            String            @db.VarChar(255)
  titleEl          String?           @db.VarChar(255)
  titleEn          String?           @db.VarChar(255)
  priceDeltaCents  Int               @default(0)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime          @updatedAt @db.Timestamp(6)
  modifier         Modifier          @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  store            Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItemOptions OrderItemOption[]

  @@unique([storeId, modifierId, slug])
  @@index([storeId, modifierId, sortOrder])
  @@map("modifier_options")
}

model ItemModifier {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId    String   @db.Uuid
  itemId     String   @db.Uuid
  modifierId String   @db.Uuid
  isRequired Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @db.Timestamp(6)
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, itemId, modifierId])
  @@unique([itemId, modifierId])
  @@index([storeId, itemId])
  @@map("item_modifiers")
}

model Table {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String        @db.Uuid
  label        String        @db.VarChar(50)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now()) @db.Timestamp(6)
  updatedAt    DateTime      @updatedAt @db.Timestamp(6)
  orders       Order[]
  customerPushSubscriptions CustomerPushSubscription[]
  qrTiles      QRTile[]
  tableVisits  TableVisit[]
  localityApprovals LocalityApproval[]
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  waiterTables WaiterTable[]

  @@unique([storeId, label])
  @@index([storeId])
  @@map("tables")
}

model QRTile {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId     String?      @db.Uuid
  tableId     String?      @db.Uuid
  publicCode  String       @unique @db.VarChar(32)
  label       String?      @db.VarChar(100)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamp(6)
  updatedAt   DateTime     @updatedAt @db.Timestamp(6)
  store       Store?       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table       Table?       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableVisits TableVisit[]
  localityApprovals LocalityApproval[]

  @@unique([storeId, tableId])
  @@index([storeId])
  @@index([tableId])
  @@map("qr_tiles")
}

model TableVisit {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String           @db.Uuid
  tableId      String           @db.Uuid
  tileId       String           @db.Uuid
  sessionToken String           @unique @db.VarChar(64)
  status       TableVisitStatus @default(OPEN)
  createdAt    DateTime         @default(now()) @db.Timestamp(6)
  updatedAt    DateTime         @updatedAt @db.Timestamp(6)
  expiresAt    DateTime?        @db.Timestamp(6)
  closedAt     DateTime?        @db.Timestamp(6)
  store        Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table        Table            @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tile         QRTile           @relation(fields: [tileId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([tableId])
  @@map("table_visits")
}

model LocalityApproval {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId         String   @db.Uuid
  tableId         String   @db.Uuid
  tileId          String   @db.Uuid
  approvalToken   String   @unique @db.VarChar(64)
  purpose         String   @db.VarChar(32)
  method          String   @db.VarChar(16)
  sessionId       String   @db.VarChar(64)
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  expiresAt       DateTime @db.Timestamp(6)
  consumedAt      DateTime? @db.Timestamp(6)
  consumedOrderId String?  @db.Uuid
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table           Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tile            QRTile   @relation(fields: [tileId], references: [id], onDelete: Cascade)

  @@index([storeId, tableId, expiresAt])
  @@index([approvalToken])
  @@index([consumedOrderId])
  @@map("locality_approvals")
}

model NodeAgent {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId              String             @db.Uuid
  slug                 String             @db.VarChar(100)
  displayName          String             @db.VarChar(255)
  tokenHash            String             @db.VarChar(128)
  configJson           Json?
  desiredConfigVersion Int                @default(1)
  lastAppliedVersion   Int?
  lastSeenAt           DateTime?          @db.Timestamp(6)
  status               NodeAgentStatus    @default(PENDING)
  statusMessage        String?            @db.VarChar(1000)
  lastLog              String?
  createdAt            DateTime           @default(now()) @db.Timestamp(6)
  updatedAt            DateTime           @updatedAt @db.Timestamp(6)
  store                Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  events               NodeAgentEvent[]
  claimedPendingNodes  PendingNodeAgent[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([lastSeenAt])
  @@map("node_agents")
}

model PendingNodeAgent {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeKey           String     @unique @db.VarChar(128)
  pairingHash       String     @db.VarChar(128)
  displayName       String     @db.VarChar(255)
  localHostname     String?    @db.VarChar(255)
  tailscaleHostname String?    @db.VarChar(255)
  macAddresses      Json?
  ipAddresses       Json?
  bootstrapJson     Json?
  status            String     @default("PENDING") @db.VarChar(32)
  storeId           String?    @db.Uuid
  claimedNodeId     String?    @db.Uuid
  lastSeenAt        DateTime   @default(now()) @db.Timestamp(6)
  createdAt         DateTime   @default(now()) @db.Timestamp(6)
  updatedAt         DateTime   @default(now()) @db.Timestamp(6)
  store             Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  claimedNode       NodeAgent? @relation(fields: [claimedNodeId], references: [id], onDelete: SetNull)

  @@index([status, lastSeenAt(sort: Desc)])
  @@map("pending_node_agents")
}

model NodeAgentEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId    String    @db.Uuid
  storeId   String    @db.Uuid
  ts        DateTime  @default(now()) @db.Timestamp(6)
  level     String    @db.VarChar(32)
  message   String    @db.VarChar(1000)
  metaJson  Json?
  node      NodeAgent @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, ts(sort: Desc)])
  @@index([storeId, ts(sort: Desc)])
  @@map("node_agent_events")
}

model Order {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId         String        @db.Uuid
  tableId         String        @db.Uuid
  status          OrderStatus   @default(PLACED)
  paymentStatus   PaymentStatus @default(PENDING)
  totalCents      Int           @default(0)
  note            String?       @db.VarChar(2000)
  ticketNumber    Int?
  placedAt        DateTime      @default(now()) @db.Timestamp(6)
  preparingAt     DateTime?     @db.Timestamp(6)
  readyAt         DateTime?     @db.Timestamp(6)
  servedAt        DateTime?     @db.Timestamp(6)
  cancelledAt     DateTime?     @db.Timestamp(6)
  paidAt          DateTime?     @db.Timestamp(6)
  cancelReason    String?       @db.VarChar(255)
  createdAt       DateTime      @default(now()) @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @db.Timestamp(6)
  paymentProvider String?       @db.VarChar(50)
  paymentId       String?       @db.VarChar(255)
  paymentError    String?
  orderItems      OrderItem[]
  customerPushSubscriptions CustomerPushSubscription[]
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table           Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([storeId, placedAt(sort: Desc)])
  @@index([tableId, placedAt(sort: Desc)])
  @@index([storeId, paymentStatus])
  @@map("orders")
}

model CustomerPushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String   @db.Uuid
  tableId   String   @db.Uuid
  orderId   String?  @db.Uuid
  endpoint  String   @unique @db.VarChar(1000)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId, tableId])
  @@index([orderId])
  @@map("customer_push_subscriptions")
}

model OrderItem {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String            @db.Uuid
  itemId           String            @db.Uuid
  titleSnapshot    String            @db.VarChar(255)
  unitPriceCents   Int
  quantity         Int               @default(1)
  status           OrderItemStatus   @default(PLACED)
  acceptedAt       DateTime?         @db.Timestamp(6)
  servedAt         DateTime?         @db.Timestamp(6)
  createdAt        DateTime          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime          @updatedAt @db.Timestamp(6)
  orderItemOptions OrderItemOption[]
  item             Item              @relation(fields: [itemId], references: [id])
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model OrderItemOption {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId      String         @db.Uuid
  modifierId       String         @db.Uuid
  modifierOptionId String         @db.Uuid
  titleSnapshot    String         @db.VarChar(255)
  priceDeltaCents  Int            @default(0)
  createdAt        DateTime       @default(now()) @db.Timestamp(6)
  updatedAt        DateTime       @updatedAt @db.Timestamp(6)
  modifier         Modifier       @relation(fields: [modifierId], references: [id])
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id])
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_options")
}

model KitchenCounter {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String   @db.Uuid
  slug      String   @db.VarChar(100)
  title     String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("kitchen_counters")
}

model KitchenTicketSeq {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String   @db.Uuid
  day       String   @db.VarChar(10)
  seq       Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, day])
  @@index([storeId])
  @@map("kitchen_ticket_seqs")
}

model WaiterShift {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String      @db.Uuid
  waiterId  String      @db.Uuid
  status    ShiftStatus @default(SCHEDULED)
  startedAt DateTime?   @db.Timestamp(6)
  endedAt   DateTime?   @db.Timestamp(6)
  createdAt DateTime    @default(now()) @db.Timestamp(6)
  updatedAt DateTime    @updatedAt @db.Timestamp(6)
  store     Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  waiter    Profile     @relation(fields: [waiterId], references: [id])

  @@index([storeId, status])
  @@index([waiterId])
  @@map("waiter_shifts")
}

model WaiterTable {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String   @db.Uuid
  waiterId  String   @db.Uuid
  tableId   String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamp(6)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  waiter    Profile  @relation(fields: [waiterId], references: [id])

  @@unique([storeId, waiterId, tableId])
  @@index([storeId])
  @@index([waiterId])
  @@index([tableId])
  @@map("waiter_tables")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId        String   @db.Uuid
  ts             DateTime @default(now()) @db.Timestamp(6)
  action         String   @db.VarChar(100)
  entityType     String   @db.VarChar(100)
  entityId       String?  @db.Uuid
  metaJson       Json?
  actorProfileId String?  @db.Uuid
  actorProfile   Profile? @relation(fields: [actorProfileId], references: [id])
  store          Store    @relation(fields: [storeId], references: [id])

  @@index([storeId, ts(sort: Desc)])
  @@map("audit_logs")
}

model Profile {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String?       @db.Uuid
  email        String        @db.VarChar(255)
  globalKey    String?       @unique @db.VarChar(300)
  passwordHash String        @db.VarChar(255)
  role         Role
  displayName  String?       @db.VarChar(255)
  createdAt    DateTime      @default(now()) @db.Timestamp(6)
  updatedAt    DateTime      @updatedAt @db.Timestamp(6)
  ratingAvg    Decimal?      @db.Decimal(4, 2)
  isVerified   Boolean       @default(false)
  printerTopic String?       @db.VarChar(255)
  cookTypeId   String?       @db.Uuid
  waiterTypeId String?       @db.Uuid
  auditLogs    AuditLog[]
  cookType     CookType?     @relation(fields: [cookTypeId], references: [id])
  store        Store?        @relation(fields: [storeId], references: [id])
  waiterType   WaiterType?   @relation(fields: [waiterTypeId], references: [id])
  waiterShifts WaiterShift[]
  waiterTables WaiterTable[]

  @@unique([storeId, email])
  @@index([storeId, role])
  @@index([email])
  @@index([cookTypeId])
  @@index([waiterTypeId])
  @@map("profiles")
}

enum TableVisitStatus {
  OPEN
  CLOSED
  EXPIRED
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

enum Role {
  GUEST
  WAITER
  HYBRID
  MANAGER
  COOK
  ARCHITECT
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  SERVED
  CANCELLED
  PAID
}

enum OrderItemStatus {
  PLACED
  ACCEPTED
  SERVED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum NodeAgentStatus {
  PENDING
  ONLINE
  APPLYING
  DEGRADED
  ERROR
  OFFLINE
}
